ADDR=:8194

# Comma-separated STUN/TURN URIs. TURN entries use short-lived credentials
# derived from SHHX_TURN_SECRET at page render time.
SHHX_TURN_URIS=stun:example.com:3478,turn:example.com:3478?transport=udp,turn:example.com:3478?transport=tcp

# Shared with coturn use-auth-secret/static-auth-secret.
SHHX_TURN_SECRET=replace-with-a-long-random-secret

# Optional temporary credential TTL in seconds.
SHHX_TURN_TTL_SECONDS=3600
