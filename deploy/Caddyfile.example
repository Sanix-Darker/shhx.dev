http://example.com {
	redir https://example.com{uri} permanent
}

http://www.example.com {
	redir https://example.com{uri} permanent
}

https://example.com {
	# Replace with your real certificate strategy.
	# `tls internal` is suitable for a private origin behind another TLS edge.
	tls internal
	reverse_proxy 127.0.0.1:8194
	encode gzip

	header {
		-Server
	}

	@css path *.css
	header @css Content-Type text/css

	@js path *.js
	header @js Content-Type application/javascript

	@svg path *.svg
	header @svg Content-Type image/svg+xml
}

https://www.example.com {
	tls internal
	redir https://example.com{uri} permanent
}
